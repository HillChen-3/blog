{
  "name": "blog",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./themes/custom-tailwind/static/css/tailwind.css -o ./themes/custom-tailwind/static/css/main.css --minify",
    "watch:css": "tailwindcss -i ./themes/custom-tailwind/static/css/tailwind.css -o ./themes/custom-tailwind/static/css/main.css --watch",
    "build:pelican": "./venv/bin/pelican content -s pelicanconf.py",
    "build": "npm run build:css && npm run build:pelican",
    "serve": "npm run build:css && npm run build:pelican && ./venv/bin/pelican --listen -s pelicanconf.py",
    "dev": "npm run build:css && ./venv/bin/pelican --autoreload --listen -s pelicanconf.py"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "autoprefixer": "^10.5.2",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^3.4.19"
  }
}
